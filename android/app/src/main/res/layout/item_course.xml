<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="course"
            type="io.coursepick.coursepick.presentation.course.CourseItem" />

        <variable
            name="courseItemListener"
            type="io.coursepick.coursepick.presentation.course.CourseItemListener" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        isSelected="@{course.selected}"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background_course_item_selector"
        android:onClick="@{() -> courseItemListener.select(course)}"
        android:paddingVertical="8dp"
        android:paddingStart="10dp">

        <ImageView
            android:id="@+id/courseFavoriteButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/background_favorite"
            android:onClick="@{() -> courseItemListener.toggleFavorite(course)}"
            android:padding="6dp"
            android:src="@{course.favorite ? @drawable/icon_favorite : @drawable/icon_not_favorite}"
            app:layout_constraintBottom_toBottomOf="@id/courseName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/courseName" />

        <TextView
            android:id="@+id/courseName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingHorizontal="10dp"
            android:text="@{course.name}"
            android:textColor="@color/item_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/courseInfoChips"
            app:layout_constraintEnd_toStartOf="@id/courseNavigationButton"
            app:layout_constraintStart_toEndOf="@id/courseFavoriteButton"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="석촌 호수 뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑뺑이" />

        <LinearLayout
            android:id="@+id/courseInfoChips"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/courseNavigationButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/courseName">

            <LinearLayout
                android:id="@+id/courseLength"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@drawable/background_course_detail"
                android:gravity="center_vertical"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/courseName">

                <ImageView
                    android:id="@+id/courseLengthIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/icon_length" />

                <TextView
                    android:id="@+id/courseLengthText"
                    courseLength="@{course.length}"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/item_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="5km" />
            </LinearLayout>

            <TextView
                android:id="@+id/courseDistance"
                courseDistance="@{course.distance}"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:background="@drawable/background_course_detail"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/point_primary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="@{course.distance != null ? View.VISIBLE : View.GONE}"
                app:layout_constraintBottom_toBottomOf="@id/courseLength"
                app:layout_constraintStart_toEndOf="@id/courseLength"
                app:layout_constraintTop_toTopOf="@id/courseLength"
                tools:text="10m만큼 떨어짐" />

        </LinearLayout>


        <TextView
            android:id="@+id/courseNavigationButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/background_navigate"
            android:gravity="center"
            android:onClick="@{() -> courseItemListener.navigateToCourse(course)}"
            android:paddingVertical="6dp"
            android:paddingStart="2dp"
            android:paddingEnd="8dp"
            android:text="@string/course_item_navigate_to_course_button"
            android:textColor="@color/item_primary"
            android:textSize="12sp"
            app:drawableStartCompat="@drawable/icon_navigate"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/courseDetailButton"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/courseDetailButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/course_item_navigate_to_detail_button_description"
            android:onClick="@{() -> courseItemListener.navigateToDetail(course)}"
            android:padding="12dp"
            android:src="@drawable/icon_course_detail"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/item_primary" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
